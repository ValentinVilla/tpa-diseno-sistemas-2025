@startuml
skinparam shadowing true

class Coleccion {
  - titulo: String
  - descripcion: String
  - fuente: Fuente
  - criterioPertenencia: FiltroCategoria
  + contiene(hecho: Hecho): boolean
}

class Administrador {
  - user: String
  - password: String
  + crearColeccion(titulo, descripcion, fuente, criterio)
  + aceptarSolicitud(SolicitudEliminacion solicitud)
  + rechazarSolicitud(SolicitudEliminacion solicitud)
  + importarHecho(archivo: FuenteCSV)
}

enum Origen {
  CARGAMANUAL,
  DATASET,
  CONTRIBUYENTE;
}

abstract class Fuente {
  + cargarHechos(): Stream<Hecho>
}

class FuenteEstatica {
  - pathArchivo: string
  + cargarHechos(): Stream<Hecho>
}
class SolicitudEliminacion {
  - hecho: Hecho
  - textoFundamentacion: String
  - estado: EstadoSolicitud
}

enum EstadoSolicitud {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

class Contribuyente {
   - solicitarEliminacion(Hecho hecho, String textoFundamentacion)
 }

class Visualizador {
  + navegarUnaColeccion(Coleccion coleccion)
  + navegarUnaColeccionSegunUnFiltro(Coleccion coleccion, Filtro filtro)
}

interface Filtro {
  +boolean cumple(Hecho hecho);
 }

class FiltroCategoria {
- categoria: String
+ cumple(hecho: Hecho): boolean
}

class FiltroFecha {
  - fechaBuscada : LocalDate
  + cumple(hecho: Hecho): boolean
}

class FiltroUbicacion {
  -latitudMin: Double
  -latitudMax: Double
  -longitudMin: Double
  -longitudMax: Double
  +cumple(hecho: Hecho): boolean
}

abstract class Hecho {
  - titulo: String
  - descripcion: String
  - categoria: String
  - latitud: Double
  - longitud: Double
  - fechaAcontecimiento: LocalDate
  - fechaCarga: LocalDate
  - origen: Origen
}

Coleccion --> Hecho
Coleccion --> Fuente

Hecho --> Origen

FuenteEstatica ..|> Fuente

Visualizador --> Hecho
Visualizador --> Filtro
Visualizador --> Coleccion
Contribuyente --> SolicitudEliminacion

Contribuyente --|> Visualizador
Administrador --|> Contribuyente

SolicitudEliminacion --> Hecho
SolicitudEliminacion --> EstadoSolicitud

FiltroCategoria ..|> Filtro
FiltroFecha ..|> Filtro
FiltroUbicacion ..|> Filtro

@enduml
