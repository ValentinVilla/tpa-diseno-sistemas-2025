<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear Colección</title>
    <link rel="stylesheet" href="/styles/variables.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/admin-colecciones.css" />
    <link rel="stylesheet" href="/styles/admin-colecciones-gestion.css" />
</head>
<body>
<section class="admin-panel">
    <div class="container">
        <div class="page-header">
            <div>
                <h1 class="page-title">Crear Colección</h1>
                <p class="subtitle">Crear nueva colección</p>
            </div>
            <div>
                <a href="/admin/colecciones" class="btn-back">← Volver a Colecciones</a>
            </div>
        </div>

        <form id="create-form" action="/admin/colecciones" method="post" style="margin-top:1rem; max-width:720px;">
            <div class="form-row">
                <label for="titulo">Título</label>
                <input id="titulo" name="titulo" type="text" required class="input" />
            </div>

            <div class="form-row">
                <label for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion" class="input" rows="3" required></textarea>
            </div>

            <div class="form-row">
                <label for="algoritmo">Algoritmo de consenso</label>
                <select id="algoritmo" name="algoritmo" class="input" required>
                    <option value="MAYORIA_SIMPLE">Mayoría simple</option>
                    <option value="ABSOLUTO">Absoluto</option>
                    <option value="MULTIPLES_MENCIONES">Múltiples menciones</option>
                    <option value="DEFAULT">Default</option>
                </select>
            </div>

            <div class="form-row">
                <label for="fuente">Fuente</label>
                <select id="fuente" name="fuente" class="input">
                    <option value="">-- Seleccionar fuente --</option>
                    {{#each FUENTESACTIVAS}}
                        <option value="{{fuente_id}}" data-tipo="{{tipo}}" data-titulo="{{titulo}}">
                            {{titulo}} ({{tipo}})
                        </option>
                    {{/each}}
                </select>
            </div>

            <div class="form-row">
                <label for="criterio">Criterio (descripción)</label>
                <textarea id="criterio" name="criterio" class="input" rows="3"></textarea>
            </div>

            <div class="form-row">
                <label for="navegacion">Forma De Navegacion</label>
                <select id="navegacion" name="navegacion" class="input" required>
                    <option value="">-- Seleccionar --</option>
                    <option value="IRRESTRICTA">Irrestricta</option>
                    <option value="CURADA">Curada</option>
                </select>
            </div>

            <div style="display:flex; gap:0.5rem; margin-top:1rem; justify-content:flex-start;">
                <a href="/admin/colecciones" class="btn btn-danger">Cancelar</a>
                <button type="submit" class="btn btn-eseverde">Crear colección</button>
            </div>
        </form>
    </div>
</section>

<script>
    document.getElementById('create-form').addEventListener('submit', function(e){
        e.preventDefault();

        const titulo = document.getElementById('titulo').value.trim();
        const descripcion = document.getElementById('descripcion').value.trim();
        const algoritmo = document.getElementById('algoritmo').value;
        const fuente = document.getElementById('fuente').value;
        const criterio = document.getElementById('criterio').value.trim();
        const navegacion = document.getElementById('navegacion').value;

        if (!titulo) {
            alert('El título es obligatorio');
            document.getElementById('titulo').focus();
            return;
        }
        if (!descripcion) {
            alert('La descripción no puede ser vacía');
            document.getElementById('descripcion').focus();
            return;
        }
        if (!navegacion) {
            alert('Seleccione la forma de navegación');
            document.getElementById('navegacion').focus();
            return;
        }

        fetch('/admin/colecciones', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ titulo, descripcion, algoritmo, fuente, criterio, navegacion })
        }).then(r => {
            if (r.ok) window.location.href = '/admin/colecciones';
            else r.text().then(t => alert('Error al crear la colección: ' + t));
        }).catch(err => {
            alert('Error de red al crear la colección');
            console.error(err);
        });
    });
</script>
</body>
</html>
