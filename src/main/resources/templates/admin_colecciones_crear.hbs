<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MetaMapa - Crear Colección</title>
    <link rel="stylesheet" href="/styles/variables.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/admin-colecciones.css" />
</head>
<body>
<section class="admin-panel">
    <div class="container">
        <div class="admin-header" style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
            <div class="title-block" style="flex:1">
                <h1 class="page-title" style="color: #004d40; margin:0">Colecciones</h1>
                <p class="subtitle">Crear y gestionar colecciones</p>
            </div>
        </div>
            <div class="admin-header-actions">
                <a href="/admin" class="btn btn-secondary btn-back">Volver al panel</a>
            </div>

        <div class="admin-section">
            <h2 style="color:#004d40">Crear colección</h2>

            <details>
                <summary class="btn btn-eseverde">+ Nueva colección</summary>

                <form action="/admin/colecciones" method="post" class="colecciones-form" style="margin-top:1rem;">
                    <div class="form-row">
                        <label for="titulo">Título</label>
                        <input id="titulo" name="titulo" type="text" required class="input" />
                    </div>

                    <div class="form-row">
                        <label for="descripcion">Descripción</label>
                        <textarea id="descripcion" name="descripcion" rows="3" class="input"></textarea>
                    </div>

                    <div class="form-row">
                        <label for="fuentes">Fuentes (mantener presionado Ctrl/Cmd para múltiples)</label>
                        <select id="fuentes" name="fuentes" multiple size="4" class="input" required>
                            <!-- Opciones predeterminadas: modificá según lo que quieras exponer -->
                            <option value="fuente_estatica">Fuente Estática</option>
                            <option value="fuente_dinamica">Fuente Dinámica</option>
                            <option value="fuente_proxy">Fuente Proxy</option>
                            <option value="fuente_externa">Fuente Externa</option>
                        </select>
                        <small class="muted">Seleccioná una o más fuentes.</small>
                    </div>

                    <div class="form-row">
                        <label for="fuenteNombre">Nombre de la fuente (opcional)</label>
                        <input id="fuenteNombre" name="fuenteNombre" type="text" class="input" placeholder="Ej: Hechos del CSV institucional" />
                        <small class="muted">Si lo dejás vacío, se mostrará el tipo de fuente.</small>
                    </div>

                    <div class="form-row">
                        <label for="criterio">Criterio de pertenencia</label>
                        <select id="criterio" name="criterio" class="input" required>
                            <!-- Opciones predeterminadas para criterio de pertenencia -->
                            <option value="filtro_geografico">Filtro geográfico</option>
                            <option value="filtro_categoria">Filtro por categoría</option>
                            <option value="filtro_fecha">Filtro por fecha</option>
                        </select>
                    </div>

                    <div class="form-row">
                        <label for="algoritmo">Algoritmo de consenso</label>
                        <select id="algoritmo" name="algoritmo" class="input" required>
                            <!-- Opciones predeterminadas de algoritmo -->
                            <option value="mayoria">Mayoría</option>
                            <option value="unanimidad">Unanimidad</option>
                            <option value="ponderado">Ponderado</option>
                        </select>
                    </div>

                    <div class="form-row">
                        <label for="modo">Modo de navegación</label>
                        <select id="modo" name="modo" class="input" required>
                            <!-- Opciones predeterminadas de modo -->
                            <option value="lista">Lista</option>
                            <option value="mapa">Mapa</option>
                            <option value="paginado">Paginado</option>
                        </select>
                    </div>

                    <div class="form-row" style="margin-top:1rem; display:flex; gap:0.5rem;">
                        <button type="submit" class="btn btn-eseverde">Crear colección</button>
                        <a href="/admin/colecciones" class="btn btn-danger">Cancelar</a>
                    </div>
                </form>
            </details>
        </div>
    </div>
</section>
</body>
</html>