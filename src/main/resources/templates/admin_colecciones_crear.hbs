<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear Colección</title>
    <link rel="stylesheet" href="/styles/variables.css" />
    <link rel="stylesheet" href="/styles/admin.css" />
    <link rel="stylesheet" href="/styles/admin-colecciones.css" />
    <link rel="stylesheet" href="/styles/admin-colecciones-gestion.css" />
</head>
<body>
<section class="admin-panel">
    <div class="container">
        <div class="page-header">
            <div>
                <h1 class="page-title">Crear Colección</h1>
                <p class="subtitle">Crear nueva colección</p>
            </div>
            <div>
                <a href="/admin/colecciones" class="btn-back">← Volver a Colecciones</a>
            </div>
        </div>

        <form id="create-form" action="/admin/colecciones" method="post" style="margin-top:1rem; max-width:720px;">
            <div class="form-row">
                <label for="titulo">Título</label>
                <input id="titulo" name="titulo" type="text" required class="input" />
            </div>

            <div class="form-row">
                <label for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion" class="input" rows="3" required></textarea>
            </div>

            <div class="form-row">
                <label for="algoritmo">Algoritmo de consenso</label>
                <select id="algoritmo" name="algoritmo" class="input" required>
                    <option value="MAYORIA_SIMPLE">Mayoría simple</option>
                    <option value="ABSOLUTO">Absoluto</option>
                    <option value="MULTIPLES_MENCIONES">Múltiples menciones</option>
                    <option value="DEFAULT">Default</option>
                </select>
            </div>

            <div class="form-row">
                <label for="fuente">Fuente</label>
                <select id="fuente" name="fuente" class="input">
                    <option value="">-- Seleccionar fuente --</option>
                    {{#each FUENTESACTIVAS}}
                        <option value="{{fuente_id}}" data-tipo="{{tipo}}" data-titulo="{{titulo}}">
                            {{titulo}} ({{tipo}})
                        </option>
                    {{/each}}
                </select>
            </div>

            <div class="form-row">
                <label for="criterio_sel">Criterio (filtro)</label>
                <select id="criterio_sel" class="input">
                    <option value="">-- Seleccionar criterio existente --</option>
                    {{#each FILTROS_ACTIVOS}}
                        <option value="{{id}}" data-tipo="{{tipo}}">{{descripcion}} ({{tipo}})</option>
                    {{/each}}
                    <option value="__nuevo">+ Crear nuevo criterio...</option>
                </select>
            </div>

            <div id="nuevo-criterio" style="display:none; margin-top:0.5rem;">
                <div class="form-row">
                    <label for="criterioTipo">Tipo de criterio</label>
                    <select id="criterioTipo" class="input">
                        <option value="TEXTO">Texto</option>
                        <option value="CATEGORIA">Categoría</option>
                    </select>
                </div>
                <div class="form-row" id="campo-criterio-texto">
                    <label for="criterio">Texto a buscar</label>
                    <input id="criterio-texto" class="input" />
                </div>
                <div class="form-row" id="campo-criterio-categoria" style="display:none;">
                    <label for="criterio-categoria">Nombre de la categoría</label>
                    <input id="criterio-categoria" class="input" />
                </div>
            </div>

            <div class="form-row">
                <label for="navegacion">Forma De Navegacion</label>
                <select id="navegacion" name="navegacion" class="input" required>
                    <option value="">-- Seleccionar --</option>
                    <option value="IRRESTRICTA">Irrestricta</option>
                    <option value="CURADA">Curada</option>
                </select>
            </div>

            <div style="display:flex; gap:0.5rem; margin-top:1rem; justify-content:flex-end;">
                <a href="/admin/colecciones" class="btn btn-danger">Cancelar</a>
                <button type="submit" class="btn btn-eseverde">Crear colección</button>
            </div>
        </form>
    </div>
</section>

<script>
    document.getElementById('create-form').addEventListener('submit', function(e){
        e.preventDefault();

        const titulo = document.getElementById('titulo').value.trim();
        const descripcion = document.getElementById('descripcion').value.trim();
        const algoritmo = document.getElementById('algoritmo').value;
        const fuente = document.getElementById('fuente').value;
        // criterio: si se eligió filtro existente enviar criterioId; si se creó nuevo enviar criterioTipo y criterio
        const criterioSel = document.getElementById('criterio_sel').value;
        let criterio = document.getElementById('criterio-texto') ? document.getElementById('criterio-texto').value.trim() : '';
        let criterioCategoria = document.getElementById('criterio-categoria') ? document.getElementById('criterio-categoria').value.trim() : '';
        const navegacion = document.getElementById('navegacion').value;

        if (!titulo) {
            alert('El título es obligatorio');
            document.getElementById('titulo').focus();
            return;
        }
        if (!descripcion) {
            alert('La descripción no puede ser vacía');
            document.getElementById('descripcion').focus();
            return;
        }
        if (!navegacion) {
            alert('Seleccione la forma de navegación');
            document.getElementById('navegacion').focus();
            return;
        }

        const payload = { titulo, descripcion, algoritmo, fuente, navegacion };
        if (criterioSel && criterioSel !== '__nuevo') {
            payload.criterioId = Number(criterioSel);
        } else if (criterioSel === '__nuevo') {
            const tipo = document.getElementById('criterioTipo').value;
            payload.criterioTipo = tipo;
            if (tipo === 'TEXTO') payload.criterio = criterio;
            if (tipo === 'CATEGORIA') payload.criterio = criterioCategoria;
        }

        fetch('/admin/colecciones', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(r => {
            if (r.ok) window.location.href = '/admin/colecciones';
            else r.text().then(t => alert('Error al crear la colección: ' + t));
        }).catch(err => {
            alert('Error de red al crear la colección');
            console.error(err);
        });
    });

    // manejo de la UI para mostrar campos de nuevo criterio
    document.getElementById('criterio_sel').addEventListener('change', function(){
        const v = this.value;
        const nuevo = document.getElementById('nuevo-criterio');
        if (v === '__nuevo') {
            nuevo.style.display = '';
        } else {
            nuevo.style.display = 'none';
        }
    });
    document.getElementById('criterioTipo').addEventListener('change', function(){
        const t = this.value;
        document.getElementById('campo-criterio-texto').style.display = (t === 'TEXTO') ? '' : 'none';
        document.getElementById('campo-criterio-categoria').style.display = (t === 'CATEGORIA') ? '' : 'none';
    });
</script>
</body>
</html>
