<div class="hechos-lista">
    {{#if hechos}}
        {{#each hechos}}
            <article class="hecho-card" tabindex="0"
                     aria-label="Hecho: {{titulo}}{{#if provincia}} en {{provincia}}{{/if}}">
                <div class="hecho-header">
                    {{#if categoria}}
                        <span class="category-badge" data-badge="{{categoria}}">{{categoria}}</span>
                    {{/if}}
                    {{#if fechaCarga}}
                        <time class="hecho-fecha" datetime="{{fechaCarga}}">{{fechaCarga}}</time>
                    {{/if}}
                </div>
                <h3 class="hecho-titulo">{{titulo}}</h3>
                <p class="hecho-descripcion">{{descripcion}}</p>
                <div class="hecho-footer">
                                        <span class="hecho-ubicacion">
                                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                                                 aria-hidden="true">
                                                <path
                                                        d="M7 1C4.79 1 3 2.79 3 5C3 8.5 7 13 7 13C7 13 11 8.5 11 5C11 2.79 9.21 1 7 1Z"
                                                        stroke="currentColor" stroke-width="1.5"/>
                                            </svg>
                                            {{#if provincia}}
                                                {{provincia}}
                                            {{else}}
                                                Sin ubicación
                                            {{/if}}
                                        </span>
                    <a href="/hechos/delete?titulo={{titulo}}&descripcion={{descripcion}}&categoria={{categoria}}"
                    class="btn-icon delete-icon"
                    aria-label="Solicitar eliminación de {{titulo}}"
                    title="Solicitar eliminación">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M2 4H14M6 7V11M10 7V11M3 4L4 13H12L13 4" stroke="currentColor"
                              stroke-width="1.5"/>
                    </svg>
                    </a>
                </div>
            </article>
        {{/each}}
    {{else}}
        <div class="empty-state">
            <div class="empty-illustration" aria-hidden="true">🗺️</div>
            <h3>No hay hechos en esta colección</h3>
            <p>Esta colección aún no contiene hechos.</p>
        </div>
    {{/if}}
</div>