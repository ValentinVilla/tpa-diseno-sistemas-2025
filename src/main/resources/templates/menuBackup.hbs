{{#partial "contenido"}}

    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                    Conecta, comparte y crea <span class="text-primary">impacto real</span>
                </h1>
                <p class="hero-description">
                    Mapea y organiza información confiable de manera segura y colaborativa.
                    Explora, contribuye y genera conocimiento útil para tu comunidad.
                </p>
                <div class="hero-actions">
                    <a href="mapa.html" class="btn btn-primary btn-lg">
                        Explorar Mapa
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </a>
                    <a href="#colecciones" class="btn btn-outline btn-lg">Ver Colecciones</a>
                </div>
            </div>
        </div>
    </section>

    <section class="features-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">¿Cómo funciona MetaMapa?</h2>
                <p class="section-description">
                    Un sistema descentralizado diseñado para maximizar la transparencia y disponibilidad de información crítica
                </p>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </div>
                    <h3 class="feature-title">Visualiza</h3>
                    <p class="feature-description">
                        Explora hechos geográficamente ubicados en un mapa interactivo. Filtra por fecha, categoría, ubicación y
                        fuente de datos.
                    </p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="17 8 12 3 7 8"></polyline>
                            <line x1="12" y1="3" x2="12" y2="15"></line>
                        </svg>
                    </div>
                    <h3 class="feature-title">Contribuye</h3>
                    <p class="feature-description">
                        Sube información de forma anónima o registrada. Incluye descripciones, imágenes, audios y videos con
                        ubicación temporal y geográfica.
                    </p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">Protege</h3>
                    <p class="feature-description">
                        Tu privacidad es fundamental. No recopilamos datos de visitantes y protegemos la identidad de quienes
                        contribuyen información.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="architecture-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Arquitectura descentralizada</h2>
                <p class="section-description">
                    Información almacenada en múltiples nodos para garantizar disponibilidad y resistencia a ataques
                </p>
            </div>

            <div class="architecture-grid">
                <div class="architecture-card">
                    <svg class="architecture-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
                    </svg>
                    <h3 class="architecture-title">Fuentes Estáticas</h3>
                    <p class="architecture-description">Datasets conocidos y verificados</p>
                </div>
                <div class="architecture-card">
                    <svg class="architecture-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    <h3 class="architecture-title">Fuentes Dinámicas</h3>
                    <p class="architecture-description">Contribuciones colaborativas</p>
                </div>
                <div class="architecture-card">
                    <svg class="architecture-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                    <h3 class="architecture-title">Fuentes Proxy</h3>
                    <p class="architecture-description">Integraciones con otras ONGs</p>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2 class="cta-title">Comienza a explorar ahora</h2>
                <p class="cta-description">
                    Accede de forma anónima para visualizar información o regístrate para contribuir con datos
                </p>
                <div class="cta-actions">
                    <a href="mapa.html" class="btn btn-primary btn-lg">Explorar sin registro</a>
                    <a href="#registro" class="btn btn-outline btn-lg">Crear cuenta</a>
                </div>
            </div>
        </div>
    </section>
{{/partial}}

{{>templates/main}}
