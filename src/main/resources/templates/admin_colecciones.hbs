<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MetaMapa - Colecciones</title>
    <link rel="stylesheet" href="/styles/variables.css">
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="/styles/admin-colecciones.css">
</head>
<body>
<section class="admin-panel">
    <div class="container">
        <div class="page-header">
            <div>
                <h1 class="page-title">Colecciones</h1>
                <p class="subtitle">Crear y gestionar colecciones desde el panel administrativo</p>
            </div>
            <div>
                <a href="/admin/colecciones/nueva" class="btn-new">+ Nueva colección</a>
                <a href="/admin" class="btn-back">← Volver al Panel</a>
            </div>
        </div>

        <div style="margin:1rem 0 1.5rem; display:flex; gap:0.75rem; align-items:center;">
            <input id="search" aria-label="Buscar colecciones" type="search" placeholder="Buscar por título, descripción, fuente..." class="input" style="flex:1; padding:0.6rem;" />
            <select id="filter-fuente" aria-label="Filtrar por fuente" class="input" style="width:220px;">
                <option value="">Todas las fuentes</option>
                <option value="FuenteEstatica">Fuente Estática</option>
                <option value="FuenteDinamica">Fuente Dinámica</option>
                <option value="FuenteProxy">Fuente Proxy</option>
            </select>
        </div>

        <div class="scroll-container">
            <table class="table" id="colecciones-table" style="width:100%; border-collapse:collapse;">
                <thead>
                <tr>
                    <th style="text-align:left; padding:0.75rem">Título</th>
                    <th style="text-align:left; padding:0.75rem">Descripción</th>
                    <th style="text-align:left; padding:0.75rem">Fuente</th>
                    <th style="text-align:left; padding:0.75rem">Criterio</th>
                    <th style="text-align:left; padding:0.75rem">Modo</th>
                    <th style="text-align:left; padding:0.75rem">Consenso</th>
                    <th style="text-align:center; padding:0.75rem">Acciones</th>
                </tr>
                </thead>
                <tbody>
                {{#each colecciones}}
                    <tr id="row-{{this.id}}" data-fuente-class="{{this.fuenteClass}}">
                        <td style="padding:0.75rem; vertical-align:top">{{this.titulo}}</td>
                        <td style="padding:0.75rem; vertical-align:top">{{this.descripcion}}</td>
                        <td style="padding:0.75rem; vertical-align:top">{{#if this.fuente.nombre}}{{this.fuente.nombre}}{{else}}{{this.fuente}}{{/if}}</td>
                        <td style="padding:0.75rem; vertical-align:top">{{#if this.criterioPertenencia.nombre}}{{this.criterioPertenencia.nombre}}{{else}}{{this.criterioPertenencia}}{{/if}}</td>
                        <td style="padding:0.75rem; vertical-align:top">{{this.modoNavegacion}}</td>
                        <td style="padding:0.75rem; vertical-align:top">{{this.algoritmoConsenso}}</td>
                        <td style="padding:0.75rem; text-align:center; vertical-align:top">
                            <button class="btn btn-sm" onclick="irA('gestionar','{{this.id}}')">Gestionar</button>
                            <button class="btn btn-sm btn-eseverde" onclick="abrirConfig('{{this.id}}', '{{this.algoritmoConsenso}}', '{{#if this.fuente}}{{this.fuente}}{{else}}null{{/if}}')">Configurar</button>
                            <button class="btn btn-sm" onclick="irA('ver','{{this.id}}')">Ver</button>
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>

            {{#unless colecciones}}
                <p style="padding:1rem;">No hay colecciones registradas.</p>
            {{/unless}}
        </div>

    </div>
</section>

<!-- Modal configuración rápida -->
<div id="config-modal" class="coleccion-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="coleccion-modal__content">
        <button class="coleccion-modal__close" onclick="cerrarConfig()">×</button>
        <h3 class="coleccion-modal__title">Configurar colección</h3>
        <form id="config-form" method="post">
            <input type="hidden" id="config-id" name="id">

            <div class="form-row">
                <label for="config-algoritmo">Algoritmo de consenso</label>
                <select id="config-algoritmo" name="algoritmo" class="input">
                    <option value="MAYORIA_SIMPLE">Mayoría simple</option>
                    <option value="ABSOLUTO">Absoluto</option>
                    <option value="MULTIPLES_MENCIONES">Múltiples menciones</option>
                    <option value="DEFAULT">Default</option>
                </select>
            </div>

            <div class="form-row">
                <label for="config-fuente">Tipo de fuente</label>
                <select id="config-fuente" name="fuenteTipo" class="input">
                    <option value="fuente_estatica">Fuente Estática</option>
                    <option value="fuente_dinamica">Fuente Dinámica</option>
                    <option value="fuente_proxy">Fuente Proxy</option>
                </select>
            </div>

            <div style="display:flex; gap:0.5rem; margin-top:1rem; justify-content:flex-end;">
                <button type="button" class="btn" onclick="cerrarConfig()">Cancelar</button>
                <button type="submit" class="btn btn-eseverde">Guardar</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Filtrado simple en el cliente para facilitar búsquedas rápidas
    const searchInput = document.getElementById('search');
    const filterFuente = document.getElementById('filter-fuente');
    const tableBody = document.querySelector('#colecciones-table tbody');

    function normalize(text) {
        return (text || '').toString().toLowerCase();
    }

    function filterRows() {
        const q = normalize(searchInput.value);
        const fuenteFilter = filterFuente.value.toLowerCase();
        const rows = tableBody.querySelectorAll('tr');

        rows.forEach(row => {
            // buscar en todas las celdas de la fila
            const cells = Array.from(row.cells);
            const rowText = cells.map(c => normalize(c.textContent)).join(' ');

            // además tomar la clase de la fuente expuesta en data-fuente-class
            const fuenteClass = (row.getAttribute('data-fuente-class') || '').toString().toLowerCase();

            const matchesQuery = q === '' || rowText.includes(q);
            const matchesFuente = fuenteFilter === '' || fuenteClass.includes(fuenteFilter);

            if (matchesQuery && matchesFuente) row.style.display = '';
            else row.style.display = 'none';
        });
    }

    searchInput.addEventListener('input', filterRows);
    filterFuente.addEventListener('change', filterRows);

    // Navegación a acciones de colección
    function irA(accion, id) {
        if (!id) return;
        if (accion === 'gestionar') window.location.href = `/admin/colecciones/${id}/gestionar`;
        else if (accion === 'configurar') window.location.href = `/admin/colecciones/${id}/configurar`;
        else window.location.href = `/admin/colecciones/${id}`;
    }

    function abrirConfig(id, algoritmo, fuenteClass) {
        const modal = document.getElementById('config-modal');
        document.getElementById('config-id').value = id;
        const selectAlg = document.getElementById('config-algoritmo');
        // Intentamos seleccionar la opción si coincide
        for (const opt of selectAlg.options) {
            if (opt.value === algoritmo) {
                opt.selected = true; break;
            }
        }
        // Fuente: no intentamos mapear la clase perfecta acá, dejamos que admin elija
        document.getElementById('config-fuente').value = 'fuente_estatica';

        modal.classList.add('show-modal');
        modal.setAttribute('aria-hidden','false');
    }

    function cerrarConfig(){
        const modal = document.getElementById('config-modal');
        modal.classList.remove('show-modal');
        modal.setAttribute('aria-hidden','true');
    }

    // Envío del formulario de config a la ruta apropiada
    document.getElementById('config-form').addEventListener('submit', function(e){
        e.preventDefault();
        const id = document.getElementById('config-id').value;
        const algoritmo = document.getElementById('config-algoritmo').value;
        const fuenteTipo = document.getElementById('config-fuente').value;

        // POST usando fetch para /admin/colecciones/:id/configurar
        fetch(`/admin/colecciones/${id}/configurar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ algoritmo: algoritmo, fuenteTipo: fuenteTipo })
        }).then(r => {
            if (r.ok) {
                window.location.reload();
            } else {
                alert('Error al guardar la configuración');
            }
        });
    });
</script>

</body>
</html>