<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Colecciones</title>
    <style>
        body { font-family: sans-serif; margin: 2rem; }
        .coleccion { border: 1px solid #ccc; border-radius: 8px; padding: 1rem; margin-bottom: 1rem; }
        .titulo { font-size: 1.3rem; font-weight: bold; color: #0070f3; }
        .desc { color: #555; margin: 0.5rem 0; }
        .info { font-size: 0.9rem; color: #777; }
    </style>
</head>
<body>
<h1>📚 Colecciones</h1>

{{#each colecciones}}
    <div class="coleccion">
        <div class="titulo">{{titulo}}</div>
        <div class="desc">{{descripcion}}</div>
        <div class="info">
            Categoría: {{categoria}} | Fuente: {{fuente}} | Hechos: {{hechos}} | Fecha: {{ultimaActualizacion}}
        </div>
    </div>
{{/each}}
</body>
</html>
