<header class="header">
    <div class="container">
        <div class="header-content">
            <div class="header-left">
                <a href="/" class="logo-link" style="text-decoration: none; display: flex; align-items: center;">
                    <div class="logo-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                    </div>
                    <span class="logo-text">MetaMapa</span>
                </a>
            </div>
            <nav class="nav">
                <a href="/hechos" class="nav-link">Mapa</a>
                <a href="/colecciones" class="nav-link">Colecciones</a>
                <a href="#contribuir" class="nav-link">Contribuir</a>
            </nav>
            <div class="header-actions">
                {{#if nombre}}
                    {{! Si está logueado, muestra su nombre y logout }}
                    <span style="margin-right: 15px; color: #333; font-weight: 500;">Hola, {{nombre}}</span>
                    <a href="/logout" class="btn btn-ghost">Cerrar Sesión</a>
                {{else}}
                    {{! Si es anónimo, muestra el botón de login }}
                    <a href="#" class="btn btn-ghost" id="login-btn">Iniciar Sesión</a>
                {{/if}}
                <a href="/hechos/nuevo" class="btn btn-primary">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                        <path d="M10 3V17M3 10H17" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    Agregar Hecho
                </a>
            </div>
        </div>
    </div>
</header>