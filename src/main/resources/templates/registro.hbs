<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registro de usuario</title>
    <link rel="stylesheet" href="/styles/saludo.css">
</head>
<body>
<h2>Registro de usuario</h2>
<form action="/usuarios" method="post" autocomplete="off">
    <label for="nombre">Nombre:</label>
    <input type="text" id="nombre" name="nombre" required pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" title="Solo letras" maxlength="50">
    <br>
    <label for="apellido">Apellido:</label>
    <input type="text" id="apellido" name="apellido" required pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" title="Solo letras" maxlength="50">
    <br>
    <label for="telefono">Teléfono:</label>
    <input type="tel" id="telefono" name="telefono" required pattern="[0-9]{8,15}" title="Ingrese solo números, mínimo 8 dígitos" maxlength="15">
    <br>
    <label for="mail">Mail:</label>
    <input type="email" id="mail" name="mail" required maxlength="100">
    <br>
    <label for="edad">Edad:</label>
    <input type="number" id="edad" name="edad" required min="1" max="120">
    <br>
    <button type="submit">Registrar</button>
</form>

</body>
</html>
