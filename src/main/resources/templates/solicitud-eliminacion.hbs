{{#partial "css"}}
    <link rel="stylesheet" href="/styles/crear-hecho.css">
{{/partial}}

{{#partial "header"}}
    {{> templates/nav }}
{{/partial}}

{{#partial "mapa-home"}}{{/partial}}
{{#partial "acerca"}}{{/partial}}

{{#partial "contenido"}}
    <div class="hecho-container">
        <svg class="registro-logo" viewBox="0 0 32 32" fill="none" aria-hidden="true" style="display: block; width: 52px; height: 52px; margin: 0 auto 8px auto; color: var(--color-primary);">
            <path d="M16 4L4 10L16 16L28 10L16 4Z" fill="currentColor"/>
            <path d="M4 16L16 22L28 16" stroke="currentColor" stroke-width="2"/>
            <path d="M4 22L16 28L28 22" stroke="currentColor" stroke-width="2"/>
        </svg>

        <h2>Solicitar Eliminación</h2>
        <p style="text-align: center; margin-bottom: 20px; color: var(--color-muted-foreground);">
            Estás solicitando eliminar el hecho:
        </p>

        <label>Hecho a eliminar</label>
        <input type="text" value="{{hecho.titulo}}" disabled>

        <form action="/hechos/delete" method="post">
            <input type="hidden" name="titulo" value="{{hecho.titulo}}">
            <input type="hidden" name="descripcion" value="{{hecho.descripcion}}">
            <input type="hidden" name="categoria" value="{{hecho.categoria}}">

            <label for="justificacion">Justificación (mínimo 500 caracteres)</label>
            <textarea id="justificacion" name="justificacion"
                      placeholder="Explica detalladamente por qué este hecho debería ser eliminado..."
                      required
                      minlength="500"
                      title="La justificación debe tener al menos 500 caracteres."></textarea>

            <p style="font-size: 12px; color: var(--color-muted-foreground); margin-top: -10px; margin-bottom: 15px;">
                Por favor, sé lo más detallado posible para fundamentar tu solicitud.
            </p>

            <button type="submit">Enviar Solicitud</button>
        </form>
    </div>
{{/partial}}

{{#partial "footer"}}
    {{> templates/footer}}
{{/partial}}

{{> templates/main }}